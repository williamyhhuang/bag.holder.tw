# Taiwan Stock Analysis System Configuration

# =================
# Data Storage Settings (CSV-based)
# =================
# 不再使用 PostgreSQL，改用 CSV 檔案儲存

# =================
# Redis Settings
# =================
# Redis 連線 URL（格式：redis://host:port）
REDIS_URL=redis://localhost:6379
# Redis 連線密碼（無密碼則留空）
REDIS_PASSWORD=
# 使用的 Redis 資料庫編號（預設 0）
REDIS_DB=0

# =================
# Fubon API Settings (Official SDK)
# =================
# 認證方式一：API Key（推薦）
# 取得：富邦證券開發者平台 → API 金鑰管理
FUBON_API_KEY=your_fubon_api_key_here
FUBON_API_SECRET=your_fubon_api_secret_here

# 認證方式二：憑證檔案登入
# 富邦證券帳號密碼
FUBON_USER_ID=your_fubon_user_id_here
FUBON_PASSWORD=your_fubon_password_here
# 憑證 .pfx 檔案路徑
FUBON_CERT_PATH=/path/to/your/certificate.pfx
# 憑證密碼
FUBON_CERT_PASSWORD=your_certificate_password_here

# 是否使用模擬環境（true=模擬交易，false=真實下單）
FUBON_IS_SIMULATION=true
# API 每分鐘請求上限
FUBON_RATE_LIMIT_PER_MINUTE=30

# =================
# Telegram Bot Settings
# =================
# Telegram Bot Token（從 @BotFather 取得）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 接收通知的 Chat ID（可用 @userinfobot 查詢）
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# Webhook URL（使用 polling 模式則留空）
TELEGRAM_WEBHOOK_URL=
# Webhook 驗證 secret（留空則不驗證）
TELEGRAM_WEBHOOK_SECRET=

# =================
# Application Settings
# =================
APP_NAME=tw-stock-monitor
APP_VERSION=1.0.0
# 執行環境：development | production
APP_ENV=development
# 是否開啟 debug 模式
APP_DEBUG=true
# 監聽的 host（0.0.0.0 代表所有介面）
APP_HOST=0.0.0.0
# API 服務 port
APP_PORT=8000

# =================
# Logging Settings
# =================
# 日誌等級：DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# 日誌檔案路徑
LOG_FILE_PATH=/app/logs/app.log
# 單一日誌檔大小上限
LOG_MAX_FILE_SIZE=10MB
# 日誌輪替保留份數
LOG_BACKUP_COUNT=5

# =================
# Scanner Settings
# =================
# 掃描間隔（秒）
SCAN_INTERVAL_SECONDS=300
# 每批次處理的股票數量
SCAN_BATCH_SIZE=50
# 最大並行掃描數
SCAN_MAX_CONCURRENT=10
# 啟用的市場：TSE（上市）、OTC（上櫃）
SCAN_ENABLED_MARKETS=TSE,OTC

# =================
# Stock Data Settings
# =================
# CSV 個股資料目錄路徑
DATA_STOCKS_PATH=data/stocks
# 使用者交易紀錄 CSV 路徑
DATA_USER_TRADES_PATH=data/user_trades.csv

# =================
# Strategy Settings
# =================
# RSI 設定
# RSI 超賣門檻（低於此值視為超賣）
STRATEGY_RSI_OVERSOLD_THRESHOLD=30
# RSI 超買門檻（高於此值視為超買）
STRATEGY_RSI_OVERBOUGHT_THRESHOLD=70
# RSI 計算週期（天）
STRATEGY_RSI_PERIOD=14

# 量能門檻設定（張數）
# 動能突破最低成交量
STRATEGY_MIN_VOLUME_MOMENTUM=500000
# 超賣反彈最低成交量
STRATEGY_MIN_VOLUME_OVERSOLD=300000
# 價格突破最低成交量
STRATEGY_MIN_VOLUME_BREAKOUT=1000000
# 價值型進場最低成交量
STRATEGY_MIN_VOLUME_VALUE=200000
# 高量異動最低成交量
STRATEGY_MIN_VOLUME_HIGH=2000000

# 價格設定
# 最低股價門檻（元），過濾低價股
STRATEGY_MIN_PRICE=10.0
# 動能訊號最低漲幅（%）
STRATEGY_MOMENTUM_PRICE_CHANGE=3.0
# 超賣訊號最低跌幅（%，填負數）
STRATEGY_OVERSOLD_PRICE_CHANGE=-2.0
# 價值型訊號允許跌幅下限（%）
STRATEGY_VALUE_PRICE_CHANGE_MIN=-5.0
# 價值型訊號允許漲幅上限（%）
STRATEGY_VALUE_PRICE_CHANGE_MAX=5.0

# 均線週期設定（逗號分隔）
STRATEGY_MA_PERIODS=5,10,20,60

# 評分設定
# RSI 極端值加分
STRATEGY_RSI_EXTREME_SCORE=10
# 高量加分
STRATEGY_HIGH_VOLUME_SCORE=5
# 大漲幅加分
STRATEGY_PRICE_CHANGE_HIGH_SCORE=8
# 中漲幅加分
STRATEGY_PRICE_CHANGE_MID_SCORE=5

# =================
# Futures Settings
# =================
# 監控的期貨合約（TXF=台指期，MXF=小台，MTX=微台）
FUTURES_ENABLED_CONTRACTS=TXF,MXF,MTX
# 期貨監控間隔（秒）
FUTURES_MONITOR_INTERVAL=30
# 最大持倉口數
FUTURES_MAX_POSITION_SIZE=10

# =================
# Technical Indicators Settings
# =================
# 均線週期（逗號分隔）
INDICATORS_MA_PERIODS=5,10,20,60
# RSI 計算週期
INDICATORS_RSI_PERIOD=14
# MACD 快線週期
INDICATORS_MACD_FAST=12
# MACD 慢線週期
INDICATORS_MACD_SLOW=26
# MACD 訊號線週期
INDICATORS_MACD_SIGNAL=9
# 布林通道週期
INDICATORS_BB_PERIOD=20
# 布林通道標準差倍數
INDICATORS_BB_STD_DEV=2

# =================
# Alert Settings
# =================
# 是否啟用警報通知
ALERT_ENABLED=true
# 同一訊號再次觸發的冷卻時間（分鐘）
ALERT_COOLDOWN_MINUTES=60
# 每支股票每日最多發送警報次數
ALERT_MAX_PER_STOCK_PER_DAY=5
# 每批次最多傳送警報數
ALERT_BATCH_SIZE=20

# =================
# Data Retention Settings
# =================
# CSV 資料保留天數
DATA_RETENTION_DAYS=365
# 自動清理執行間隔（小時）
CLEANUP_INTERVAL_HOURS=24
# 是否啟用自動清理
AUTO_CLEANUP_ENABLED=true

# =================
# Rate Limiting Settings
# =================
# 是否啟用 Rate Limiting
RATE_LIMIT_ENABLED=true
# Rate Limit 儲存後端：redis | memory
RATE_LIMIT_STORAGE=redis

# =================
# Security Settings
# =================
# 應用程式 secret key（請務必替換為隨機字串）
SECRET_KEY=your_secret_key_here
# 允許存取的 host（逗號分隔）
ALLOWED_HOSTS=localhost,127.0.0.1
# 允許的 CORS 來源（逗號分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =================
# Monitoring Settings
# =================
# 是否啟用 Health Check endpoint
HEALTH_CHECK_ENABLED=true
# 是否啟用 Metrics 蒐集
METRICS_ENABLED=true
# Prometheus metrics 匯出 port
PROMETHEUS_PORT=9090

# =================
# Mac Mini 2015 Optimizations
# =================
# 最大 worker 數（Mac Mini 2015 建議 2）
MAX_WORKERS=2
# 記憶體使用上限（MB）
MEMORY_LIMIT_MB=2048
# CPU 使用上限（核心數）
CPU_LIMIT=2.0
# 批次處理間延遲（秒），避免 CPU 過載
BATCH_PROCESSING_DELAY=1.0

# =================
# Development Settings
# =================
# 是否開啟程式碼異動自動重載（開發用）
DEV_AUTO_RELOAD=true
# 是否使用假的 API 回應（開發用）
DEV_MOCK_API=false
# 是否使用範例資料（開發用）
DEV_SAMPLE_DATA=false

# =================
# AI 分析器設定（支援 Claude / OpenAI / Gemini / OpenRouter）
# =================
# 選擇 AI provider：claude | openai | gemini | openrouter（預設 claude）
AI_PROVIDER=claude

# Claude (Anthropic) API Key
# 取得：https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key（使用 openai provider 時需設定）
# 取得：https://platform.openai.com → API Keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key（使用 gemini provider 時需設定）
# 取得：https://aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API Key（使用 openrouter provider 時需設定，可存取多種模型）
# 取得：https://openrouter.ai → Keys
OPENROUTER_API_KEY=

# 指定模型名稱（空白 = 各 provider 預設值）
# Claude 預設：claude-sonnet-4-6
# OpenAI 預設：gpt-4o
# Gemini 預設：gemini-2.0-flash
# OpenRouter 範例：anthropic/claude-3.5-sonnet, google/gemini-flash-1.5
AI_MODEL=

# 是否預設開啟 AI 分析（建議保持 false，用 --ai-filter flag 手動觸發）
AI_ENABLE_SIGNAL_ANALYSIS=false
# 每批最多傳給 AI 分析的股票數
AI_MAX_STOCKS_PER_BATCH=50

# =================
# Backtest Settings
# =================
# ── 回測時間範圍 ──
# 留空則使用程式預設（start: 2024-09-01，end: 今天）
# 對應 BacktestSettings.start_date / end_date（env_prefix=BACKTEST_）
BACKTEST_START_DATE=
BACKTEST_END_DATE=

# ── 停損 / 停利 ──
# 一般訊號停損比例（如 0.1 = 10%）
BACKTEST_STOP_LOSS_PCT=0.1
# 一般訊號停利比例
BACKTEST_TAKE_PROFIT_PCT=0.10
# 一般訊號移動停損比例（從高點回撤觸發）
BACKTEST_TRAILING_STOP_PCT=0.03
# 最大持倉天數
BACKTEST_MAX_HOLDING_DAYS=15

# ── 趨勢訊號出場參數（P6 + P3-B）──
# 寬停損 15% + trailing 8% 讓趨勢部位有空間奔跑，最佳配置
# 套用趨勢出場參數的訊號名稱（逗號分隔）
BACKTEST_TREND_SIGNAL_NAMES=Donchian Breakout,MACD Golden Cross
# 趨勢訊號停損比例
BACKTEST_TREND_STOP_LOSS_PCT=0.15
# 趨勢訊號移動停損比例
BACKTEST_TREND_TRAILING_STOP_PCT=0.08
# 是否使用移動停損（趨勢訊號）
BACKTEST_TREND_USE_TRAILING_STOP=true
# 趨勢訊號停利比例
BACKTEST_TREND_TAKE_PROFIT_PCT=0.40
# 趨勢訊號最大持倉天數
BACKTEST_TREND_MAX_HOLDING_DAYS=60
# 啟動移動停損所需的最低獲利門檻
BACKTEST_TREND_PROFIT_THRESHOLD_PCT=0.05
# 進入移動停損後的追蹤幅度
BACKTEST_TREND_PROFIT_TRAILING_PCT=0.06

# ── TechnicalStrategy 進場過濾（對應 strategy.py）──
# Filter 1: 停用的訊號（逗號分隔），這些訊號不會產生進場
BACKTEST_DISABLED_SIGNALS=MACD Golden Cross,Golden Cross
# Filter 2: 個股需在 MA60 上方才進場
BACKTEST_REQUIRE_MA60_UPTREND=true
# Filter 3: 量能確認（當日量 > N × MA20 量）
BACKTEST_REQUIRE_VOLUME_CONFIRMATION=true
BACKTEST_VOLUME_CONFIRMATION_MULTIPLIER=1.5
# Filter 4: MA5 > MA10 > MA20 對齊（hardcoded in strategy.py，無需額外設定）
# Filter 5: RSI 動能門檻（RSI 需高於此值才進場）
BACKTEST_RSI_MIN_ENTRY=50.0
# RSI 超買門檻（高於此值不進場）
BACKTEST_RSI_OVERBOUGHT_THRESHOLD=70.0

# ── 大盤市場環境過濾（三層 TAIEX 篩選）──
# 大盤 RSI 低於此值時暫停進場
BACKTEST_MARKET_REGIME_RSI_THRESHOLD=40.0
# 是否要求大盤 MA5 向上才進場
BACKTEST_MARKET_REGIME_CHECK_MA5=true

# ── 動能排名過濾 ──
# 每次只選動能排名前 N 支股票
BACKTEST_MOMENTUM_TOP_N=30
# 動能計算回看天數
BACKTEST_MOMENTUM_LOOKBACK_DAYS=20

# ── 產業排除 ──
# 排除的產業代碼（逗號分隔，31=金融保險）
BACKTEST_EXCLUDE_INDUSTRY_CODES=31
# 產業代碼對照表 JSON 路徑
BACKTEST_INDUSTRY_CODE_MAP_PATH=config/industry_codes.json
